# 环境变量示例文件
# 复制此文件为 .env 并填入你的实际值

# 飞书机器人 Webhook URL
# 获取方式: 飞书群 → 群设置 → 群机器人 → 添加机器人 → 自定义
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxx

# 钉钉机器人 Webhook URL（可选）
# 获取方式: 钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxxx
